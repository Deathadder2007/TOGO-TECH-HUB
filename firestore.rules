rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields:
    //   - name: string (required)
    //   - price: number (required)
    //   - category: string (required)
    //   - image: string (required)
    //   - description: string (optional)
    //   - badge: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email in ["thomwinner2007@gmail.com", "alikizanjoyce@gmail.com", "ephra888@gmail.com"] && request.auth.token.email_verified == true);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'image', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.image is string && data.image.size() > 0 &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
             (!('badge' in data) || (data.badge is string && data.badge.size() < 20)) &&
             data.createdAt is timestamp;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'icon']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.icon is string &&
             (!('description' in data) || (data.description is string && data.description.size() < 200)) &&
             (!('order' in data) || (data.order is number)) &&
             (!('type' in data) || (data.type in ['hardware', 'software', 'service', 'other']));
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(request.resource.data);
      allow update: if isAdmin() && isValidCategory(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
